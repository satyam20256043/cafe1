# ☕ Zordic California — Environment Configuration
# Copy to .env and fill in real values. Never commit .env (it's gitignored).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3010
# Public URL of the deployed server (used to build links in WhatsApp messages, etc.)
BASE_URL=http://localhost:3010

# ── Google Gemini API Key (Required for natural human-like AI responses) ─────
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT Authentication Secret ─────────────────────────────────────────────────
# REQUIRED. Must be >=32 chars and NOT a known default — the server refuses to
# boot otherwise (Phase 0 safeguard). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_EXPIRES=8h

# ── Razorpay Payment Gateway (optional — leave blank for cash-only launch) ────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Web Push notifications (optional) ─────────────────────────────────────────
# Generate a VAPID key pair: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_EMAIL=mailto:admin@example.com

# ── WhatsApp Cloud API webhook (required to enable WhatsApp) ─────────────────
# Any random string you choose — must match the "Verify token" you enter in the
# Meta App Dashboard's WhatsApp > Configuration > Webhook setup.
WHATSAPP_VERIFY_TOKEN=
