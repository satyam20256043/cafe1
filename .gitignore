cafe_hq.db
cafe_hq.db-shm
cafe_hq.db-wal
data/backups/
data/_pre-launch-db-fix-backup/
data/_archive_demo_data_*/
data/*.txt
data/server_log.txt
data/activity_log.json
*.bak
*.pre-launch.bak

# Local dev tooling (machine-specific paths)
.claude/

# OS / editor noise
Thumbs.db
.DS_Store
*.log
